{
  "name": "paperwriter-electron",
  "version": "0.8.2",
  "private": false,
  "main": "main.cjs",
  "scripts": {
    "dev": "electron .",
    "dev:vite": "node dev-vite.cjs",
    "check": "node --check main.cjs && node --check preload.cjs",
    "dist": "electron-builder --win nsis --x64",
    "pack": "electron-builder --win dir --x64",
    "publish": "electron-builder --win nsis --x64 --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "electron": "^41.5.0",
    "electron-builder": "^26.15.3"
  },
  "productName": "信笺写作",
  "description": "漂亮信纸上的个人写作软件",
  "author": "Aecenas",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aecenas/PaperWriterElectron.git"
  },
  "homepage": "https://github.com/Aecenas/PaperWriterElectron#readme",
  "build": {
    "appId": "com.aecenas.paperwriter",
    "productName": "信笺写作",
    "artifactName": "PaperWriter-${version}-${arch}.${ext}",
    "directories": {
      "output": "../../release"
    },
    "files": [
      "**/*"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend/dist"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/app-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "信笺写作"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Aecenas",
        "repo": "PaperWriterElectron"
      }
    ]
  }
}
